{
  "name": "garage61-analyser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build && npm run build:extensions",
    "build:extensions": "vite build --config vite.extension.config.ts",
    "build:extension:chrome": "vite build --config vite.extension.config.ts --mode chrome",
    "build:extension:firefox": "vite build --config vite.extension.config.ts --mode firefox",
    "preview": "vite preview --host 127.0.0.1",
    "smoke:ui": "node scripts/ui-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "playwright": "^1.61.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
