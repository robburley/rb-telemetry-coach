{
  "manifest_version": 3,
  "name": "RB Telemetry Coach Prototype",
  "version": "0.1.0",
  "description": "Private prototype panel for telemetry coaching.",
  "action": {
    "default_title": "RB Telemetry Coach"
  },
  "content_scripts": [
    {
      "matches": ["https://garage61.net/*", "https://www.garage61.net/*"],
      "js": ["pageObserver.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://garage61.net/*", "https://www.garage61.net/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": []
}
